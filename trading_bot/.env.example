# Configuration des alertes Telegram (optionnel mais recommandé)
# 
# Comment obtenir les valeurs :
# 1. Sur Telegram : parler à @BotFather, envoyer /newbot, suivre les instructions
# 2. Copier le TOKEN donné par BotFather
# 3. Démarrer une conversation avec votre nouveau bot (/start)
# 4. Parler à @userinfobot, envoyer /start, copier votre ID
# 5. Renommer ce fichier en ".env" (sans le .example) et remplir les valeurs

TELEGRAM_TOKEN=votre_token_ici_ex_123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=votre_chat_id_ici_ex_123456789
